RUNPOD_API_KEY=PUT_YOUR_RUNPOD_API_KEY_HERE
RUNPOD_IMAGE_NAME=ghcr.io/unibox-design/golf-runpod:latest

POD_NAME=parameter-golf-dev-4090
GPU_TYPE="NVIDIA GeForce RTX 4090"
GPU_COUNT=1
SECURE_CLOUD=false
CONTAINER_DISK_GB=40
VOLUME_GB=80
VOLUME_PATH=/runpod
MIN_VCPU=8
MIN_MEM_GB=32
MAX_COST_PER_HOUR=
PORTS=22/tcp

RUN_PRESET=baseline
DATA_VARIANT=sp1024
TRAIN_SHARDS=1
RESULTS_DIR=/runpod/results

EXTRA_POD_FLAGS=--startSSH
TEMPLATE_ID=
