# Copy this file to config/runpod.env and fill in the values.

# Runpod API key for runpodctl.
RUNPOD_API_KEY=

# Image to launch on Runpod. For first placement against a pinned volume,
# prefer the stock Runpod PyTorch image that is known to place.
RUNPOD_IMAGE_NAME=runpod/pytorch:2.4.0-py3.11-cuda12.4.1-devel-ubuntu22.04

# Pod settings. For initial testing, a 4090 is a good cost/speed default.
# If that is unavailable in your chosen region, the launcher can try the
# ordered fallback list in GPU_CANDIDATES automatically.
POD_NAME=parameter-golf-dev-4090
GPU_TYPE="NVIDIA GeForce RTX 4090"
GPU_CANDIDATES="NVIDIA GeForce RTX 4090;NVIDIA GeForce RTX 4080;NVIDIA A40;NVIDIA RTX PRO 4500;NVIDIA GeForce RTX 5090;NVIDIA RTX 2000 Ada;NVIDIA RTX PRO 6000;NVIDIA RTX PRO 6000 WK;NVIDIA RTX 4000 Ada;NVIDIA L4"
GPU_COUNT=1
SECURE_CLOUD=false
CONTAINER_DISK_GB=40
VOLUME_GB=10
VOLUME_PATH=/workspace
DATA_CENTER_ID=
NETWORK_VOLUME_ID=
MIN_VCPU=8
MIN_MEM_GB=32
MAX_COST_PER_HOUR=
PORTS=

# Training settings. This small-volume profile is meant for light experimentation.
RUN_PRESET=baseline_dev
DATA_VARIANT=sp1024
TRAIN_SHARDS=1
RESULTS_DIR=/workspace/results
WORKSPACE_ROOT=/workspace
AUTOMATION_ROOT=/workspace/golf
REPO_ROOT_ON_POD=/workspace/parameter-golf
VENV_ROOT=/workspace/venv
PIP_CACHE_DIR=/workspace/.cache/pip
HF_HOME=/workspace/.cache/huggingface
AUTOMATION_REPO_URL=https://github.com/unibox-design/GOLF.git

# Optional extra flags passed as-is to runpodctl create pod.
# Example: EXTRA_POD_FLAGS=--supportPublicIp
EXTRA_POD_FLAGS=
TEMPLATE_ID=
