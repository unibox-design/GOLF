{
  "baseline": {
    "description": "Single-GPU baseline with the public sp1024 setup",
    "env": {
      "RUN_ID": "baseline_sp1024",
      "DATA_PATH": "./data/datasets/fineweb10B_sp1024",
      "TOKENIZER_PATH": "./data/tokenizers/fineweb_1024_bpe.model",
      "VOCAB_SIZE": "1024",
      "VAL_LOSS_EVERY": "200"
    },
    "command": [
      "torchrun",
      "--standalone",
      "--nproc_per_node=1",
      "train_gpt.py"
    ]
  },
  "baseline_dev": {
    "description": "Single-GPU dev baseline for RTX 4090-style smoke runs with torch.compile disabled",
    "env": {
      "RUN_ID": "baseline_dev_sp1024",
      "DATA_PATH": "./data/datasets/fineweb10B_sp1024",
      "TOKENIZER_PATH": "./data/tokenizers/fineweb_1024_bpe.model",
      "VOCAB_SIZE": "1024",
      "VAL_LOSS_EVERY": "200",
      "TORCHDYNAMO_DISABLE": "1"
    },
    "command": [
      "torchrun",
      "--standalone",
      "--nproc_per_node=1",
      "train_gpt.py"
    ]
  },
  "kv2": {
    "description": "Baseline with fewer KV heads",
    "env": {
      "RUN_ID": "kv2_sp1024",
      "DATA_PATH": "./data/datasets/fineweb10B_sp1024",
      "TOKENIZER_PATH": "./data/tokenizers/fineweb_1024_bpe.model",
      "VOCAB_SIZE": "1024",
      "NUM_KV_HEADS": "2",
      "VAL_LOSS_EVERY": "200"
    },
    "command": [
      "torchrun",
      "--standalone",
      "--nproc_per_node=1",
      "train_gpt.py"
    ]
  },
  "kv2_dev": {
    "description": "Dev variant of kv2 with torch.compile disabled for RTX 4090-style runs",
    "env": {
      "RUN_ID": "kv2_dev_sp1024",
      "DATA_PATH": "./data/datasets/fineweb10B_sp1024",
      "TOKENIZER_PATH": "./data/tokenizers/fineweb_1024_bpe.model",
      "VOCAB_SIZE": "1024",
      "NUM_KV_HEADS": "2",
      "VAL_LOSS_EVERY": "200",
      "TORCHDYNAMO_DISABLE": "1"
    },
    "command": [
      "torchrun",
      "--standalone",
      "--nproc_per_node=1",
      "train_gpt.py"
    ]
  },
  "kv2_seq512_dev": {
    "description": "kv2_dev plus shorter training sequence length for a faster dev-time comparison",
    "env": {
      "RUN_ID": "kv2_seq512_dev_sp1024",
      "DATA_PATH": "./data/datasets/fineweb10B_sp1024",
      "TOKENIZER_PATH": "./data/tokenizers/fineweb_1024_bpe.model",
      "VOCAB_SIZE": "1024",
      "NUM_KV_HEADS": "2",
      "TRAIN_SEQ_LEN": "512",
      "VAL_LOSS_EVERY": "200",
      "TORCHDYNAMO_DISABLE": "1"
    },
    "command": [
      "torchrun",
      "--standalone",
      "--nproc_per_node=1",
      "train_gpt.py"
    ]
  },
  "kv2_low_lr_dev": {
    "description": "kv2_dev plus lower learning rates based on the current public LowerLR direction",
    "env": {
      "RUN_ID": "kv2_low_lr_dev_sp1024",
      "DATA_PATH": "./data/datasets/fineweb10B_sp1024",
      "TOKENIZER_PATH": "./data/tokenizers/fineweb_1024_bpe.model",
      "VOCAB_SIZE": "1024",
      "NUM_KV_HEADS": "2",
      "TIED_EMBED_LR": "0.03",
      "MATRIX_LR": "0.02",
      "SCALAR_LR": "0.02",
      "VAL_LOSS_EVERY": "200",
      "TORCHDYNAMO_DISABLE": "1"
    },
    "command": [
      "torchrun",
      "--standalone",
      "--nproc_per_node=1",
      "train_gpt.py"
    ]
  },
  "kv2_fp16_embed_dev": {
    "description": "kv2_dev plus fp16 passthrough for tok_emb.weight during export to reduce quantization damage",
    "env": {
      "RUN_ID": "kv2_fp16_embed_dev_sp1024",
      "DATA_PATH": "./data/datasets/fineweb10B_sp1024",
      "TOKENIZER_PATH": "./data/tokenizers/fineweb_1024_bpe.model",
      "VOCAB_SIZE": "1024",
      "NUM_KV_HEADS": "2",
      "INT8_KEEP_FLOAT_FP16_NAME_PATTERNS": "tok_emb.weight",
      "VAL_LOSS_EVERY": "200",
      "TORCHDYNAMO_DISABLE": "1"
    },
    "command": [
      "torchrun",
      "--standalone",
      "--nproc_per_node=1",
      "train_gpt.py"
    ]
  },
  "kv2_10l_dev": {
    "description": "kv2_dev plus one extra layer with slightly reduced width to test depth without blindly overspending bytes",
    "env": {
      "RUN_ID": "kv2_10l_dev_sp1024",
      "DATA_PATH": "./data/datasets/fineweb10B_sp1024",
      "TOKENIZER_PATH": "./data/tokenizers/fineweb_1024_bpe.model",
      "VOCAB_SIZE": "1024",
      "NUM_KV_HEADS": "2",
      "NUM_LAYERS": "10",
      "MODEL_DIM": "480",
      "VAL_LOSS_EVERY": "200",
      "TORCHDYNAMO_DISABLE": "1"
    },
    "command": [
      "torchrun",
      "--standalone",
      "--nproc_per_node=1",
      "train_gpt.py"
    ]
  },
  "mlx_smoke": {
    "description": "Apple Silicon smoke run with a short MLX training job",
    "env": {
      "RUN_ID": "mlx_smoke",
      "ITERATIONS": "200",
      "TRAIN_BATCH_TOKENS": "8192",
      "VAL_LOSS_EVERY": "0",
      "VAL_BATCH_SIZE": "8192"
    },
    "command": [
      "python3",
      "train_gpt_mlx.py"
    ]
  }
}
